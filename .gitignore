# ============================================================
# WebTestPro .gitignore
# ============================================================

# ---- 敏感配置（绝不提交）----
.env
*.env.local
*.env.prod
**/application-prod.yml
**/application-local.yml
**/vault-token

# ---- Java 编译产物 ----
target/
*.class
*.jar
*.war
*.ear

# ---- Maven ----
.mvn/wrapper/maven-wrapper.jar

# ---- IDE ----
.idea/
*.iml
*.iws
*.ipr
.vscode/settings.json
.classpath
.project
.settings/

# ---- 日志 ----
logs/
*.log
*.log.*

# ---- Docker 运行数据（不提交 volume 数据）----
docker/mysql/data/
docker/redis/data/

# ---- Node / 前端（Phase 3 准备）----
node_modules/
frontend/dist/
frontend/.env.local

# ---- 测试产物 ----
allure-results/
allure-report/
test-output/
surefire-reports/

# ---- 系统文件 ----
.DS_Store
Thumbs.db
desktop.ini

# ---- MinIO 本地数据 ----
/data/minio/

# ---- SkyWalking Agent（大文件，运行时下载）----
skywalking-agent/
